{
  "project": {
    "name": "generic_project",
    "kind": "library"
  },
  "generation_boundary": {
    "allowed_rust_files": [
      "Cargo.toml",
      "src/lib.rs",
      "src/core.rs",
      "README.md"
    ],
    "allow_tests": false,
    "allow_examples": false,
    "allow_benches": false,
    "allow_ffi": false,
    "dependency_policy": "std_only_by_default",
    "allowed_dependencies": []
  },
  "forbidden_without_evidence": [
    "thread_safe_api",
    "recovery_mechanism",
    "serde"
  ]
}