#: src/main.c:516
msgid "set the depth at which the flowgraph is cut off"
msgstr ""
"stabilește adâncimea la care este tăiat graficul de flux (înălțimea maximă a "
"arborelui)"

#: src/main.c:527
msgid "CLASSES"
msgstr "CLASE"

#: src/main.c:528
msgid ""
"include specified classes of symbols (see below); prepend CLASSES with ^ or "
"- to exclude them from the output"
msgstr ""
"include clasele specificate de simboluri (a se vedea mai jos); adaugă CLASE "
"prefixându-le cu „^” sau cu „-” pentru a le exclude din rezultat"

