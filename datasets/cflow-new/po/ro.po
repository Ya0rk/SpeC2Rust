msgid "NAME[=DEFN]"
msgstr "NUME[=DEFINIȚIE]"

#: src/main.c:691
msgid "predefine NAME as a macro"
msgstr "predefinește NUME ca macrocomandă"

#: src/main.c:702
msgid "cancel any previous definition of NAME"
msgstr "anulează orice definiție anterioară a NUME"

#: src/main.c:713
msgid ""
"add the directory DIR to the list of directories to be searched for header "
"files"
msgstr ""
"adaugă directorul DIRECTOR la lista de directoare pentru a fi căutate pentru "
"fișierele antet"

