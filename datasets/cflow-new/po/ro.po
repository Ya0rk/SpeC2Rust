#. TRANSLATORS: Don't translate type names.
#: src/main.c:677
msgid ""
"register SYMBOL with given TYPE, or define an alias (if := is used); valid "
"types are: keyword (or kw), modifier, qualifier, identifier, type, wrapper, "
"or any unambiguous abbreviation thereof"
msgstr ""
"înregistrează SIMBOLul cu TIPul dat sau definește un alias (dacă este "
"folosit :=); tipurile valide sunt: „keyword” (sau „kw”), „modifier”, "
"„qualifier”, „identifier”, „type”, „wrapper” sau orice abreviere clară a "
"acestora"

