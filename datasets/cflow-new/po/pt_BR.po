msgid "NUMBER"
msgstr "NÚMERO"

# Espaço adicionado para alinhar; veja "cflow --help"
#: src/main.c:516
msgid "set the depth at which the flowgraph is cut off"
msgstr " define a profundidade limite do grafo de fluxo"

#: src/main.c:527
msgid "CLASSES"
msgstr "CLASSES"

#: src/main.c:528
msgid ""
"include specified classes of symbols (see below); prepend CLASSES with ^ or "
"- to exclude them from the output"
msgstr ""
"inclui as classes de símbolos especificadas (veja abaixo); preceda CLASSES "
"com ^ ou - para excluí-las da saída"

