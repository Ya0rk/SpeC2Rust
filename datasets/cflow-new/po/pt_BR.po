#: src/main.c:562
msgid ""
"use given output format NAME; valid names are `gnu' (default), `posix', and "
"`dot'"
msgstr ""
"usa o NOME de formato de saída fornecido; nomes válidos são \"gnu"
"\" (padrão), \"posix\" e \"dot\""

#: src/main.c:573
msgid "print reverse call tree"
msgstr "imprime árvore de chamada reversa"

#: src/main.c:584
msgid "produce cross-reference listing only"
msgstr "produz apenas listagem de referência cruzada"

